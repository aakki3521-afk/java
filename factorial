import java.util.Scanner;
class Solution {
    
    public int factorial(int n) {
        int fact=1;
        for(int i=1;i<=n;i++){
            fact=fact*i;
            
        }return fact;
        
    }
    public static void main(String[] args){
        Scanner scan=new Scanner(System.in);
        int n=scan.nextInt();
        Solution obj=new Solution();
        System.out.println(obj.factorial(n));
    }
}

