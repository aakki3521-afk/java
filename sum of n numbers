class Solution {
    public static int nSum(int n) {
        
                int ans = 0;

        for(int i=0;i<=n;i++){
            ans=ans+i;
        }
        
        
        return ans;
    }
    public static void main(String[] args){
        Scanner scan=new Scanner(System.in);
        int n=scan.nextInt();
        Solution obj=new Solution();
        System.out.println(obj.nSum(n));
    }
}
