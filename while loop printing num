import java.util.Scanner;

class Solution {

    public static void utility(int x) {
        if (x != 0) {
            for (int i = 0; i <= x; i++) {
                System.out.println(i);
            }
        }
    }

    public static void main(String[] args) {

        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();

        utility(n);
    }
}
